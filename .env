# Sell4Me keyless checkout configuration
# Your Sell4Me store UUID (NOT the API key). Required for POST /checkout/.
VITE_SELL4ME_STORE_ID=46639064a609419090baec90b799e967

# Sell4Me API base URL (optional — defaults to https://api.sell4me.store)
VITE_SELL4ME_API_URL=https://api.sell4me.store

# Currency code sent to Sell4Me (optional — defaults to ngn).
# Docs use lowercase (usd/ghs/ngn); Paystack may require uppercase NGN.
VITE_SELL4ME_CURRENCY=USD
VITE_SELL4ME_API_KEY=sel4me_64e9fdca366a12c1737c6498f18ffdf471b9e41155f98256